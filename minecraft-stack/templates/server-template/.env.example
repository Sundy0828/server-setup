TZ=America/New_York
MC_CONTAINER_NAME=minecraft-template
MC_PORT=25565
MC_TYPE=PAPER
MC_VERSION=LATEST
MC_MEMORY=6G
MC_ENABLE_WHITELIST=false
# Only used when MC_TYPE=AUTO_CURSEFORGE:
# URL of the CurseForge modpack page (example: https://www.curseforge.com/minecraft/modpacks/all-the-mods-9)
CF_PAGE_URL=
# CurseForge API token for automated pack file downloads
CF_API_KEY=

# Optional playit.gg sidecar for remote access without port-forwarding.
# Enable with: docker compose --profile playit up -d
# Create a secret key from the playit.gg dashboard.
PLAYIT_CONTAINER_NAME=sundy-studios-playit
PLAYIT_SECRET_KEY=
