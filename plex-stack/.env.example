TZ=America/New_York
PUID=1000
PGID=1000

# Plex claim token (optional on first startup)
# Get one at https://www.plex.tv/claim/
PLEX_CLAIM=

# Gluetun VPN settings
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=10.x.x.x/32

# Tailscale auth key for Overseerr sidecar
TS_AUTHKEY=
TS_HOSTNAME=overseerr-media

# Optional: SABnzbd host UI port (container web UI is always 8080)
SABNZBD_WEBUI_PORT=8085
